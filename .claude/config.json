{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "0.1.0",
  "description": "Configuration FeedMind - Lecteur RSS intelligent avec IA",

  "thresholds": {
    "file_sizes": {
      "rust_module_max_lines": 400,
      "rust_function_max_lines": 50,
      "component_max_lines": 200,
      "hook_max_lines": 100,
      "test_max_lines": 300
    },
    "coverage": {
      "global_min": 70,
      "core_min": 85,
      "api_routes_min": 75,
      "worker_min": 80
    },
    "complexity": {
      "max_function_params": 5,
      "max_nesting_depth": 4,
      "max_imports_per_file": 20,
      "max_component_props": 8
    },
    "performance": {
      "api_response_p95_max_ms": 200,
      "feed_fetch_timeout_ms": 30000,
      "ai_request_timeout_ms": 60000,
      "bundle_size_web_max_kb": 500
    }
  },

  "paths": {
    "rust_core": "crates/core/src",
    "rust_api": "crates/api/src",
    "rust_worker": "crates/worker/src",
    "frontend_src": "apps/web/src",
    "frontend_components": "apps/web/src/components",
    "docs": "docs",
    "bmad": "_bmad",
    "hooks_dir": ".claude/hooks"
  },

  "patterns": {
    "secrets_detection": [
      "ANTHROPIC_API_KEY",
      "GOOGLE_AI_API_KEY",
      "DATABASE_URL",
      "REDIS_URL",
      "JWT_SECRET",
      "CLERK_SECRET_KEY",
      "STRIPE_SECRET_KEY",
      "password\\s*=\\s*['\"][^'\"]+['\"]",
      "api_key\\s*=\\s*['\"][^'\"]+['\"]",
      "secret\\s*=\\s*['\"][^'\"]+['\"]"
    ],
    "excluded_dirs": [
      "node_modules",
      ".git",
      "target",
      "dist",
      ".next",
      "coverage",
      ".turbo"
    ],
    "forbidden_patterns": {
      "unsafe_without_comment": "unsafe\\s*\\{(?!\\s*//)",
      "unwrap_without_expect": "\\.unwrap\\(\\)(?!\\s*//)",
      "hardcoded_colors": "(bg|text|border)-(slate|gray|zinc|neutral|stone|red|orange|amber|yellow|lime|green|emerald|teal|cyan|sky|blue|indigo|violet|purple|fuchsia|pink|rose)-\\d{3}\\b",
      "console_log_in_prod": "console\\.log\\(",
      "dbg_macro": "dbg!\\("
    }
  },

  "quality": {
    "strict_mode": true,
    "challenge_shortcuts": true,
    "test_alongside": {
      "enabled": true,
      "required_for_non_trivial": true
    }
  },

  "language": {
    "discussion": "fr",
    "code_comments": "en",
    "commit_messages": "en",
    "documentation": "fr"
  },

  "stack": {
    "backend": {
      "language": "Rust",
      "edition": "2021",
      "framework": "Axum",
      "async_runtime": "Tokio",
      "database": "PostgreSQL",
      "orm": "SQLx",
      "cache": "Redis",
      "queue": "Redis + custom"
    },
    "frontend": {
      "runtime": "Bun",
      "framework": "Next.js 15",
      "react_version": "19",
      "ui_library": "Shadcn UI",
      "styling": "Tailwind CSS",
      "state": "Zustand",
      "data_fetching": "TanStack Query"
    },
    "ai": {
      "model": "BYOK",
      "providers": ["anthropic", "google"],
      "fallback": "none"
    }
  },

  "features": {
    "v1_mvp": [
      "import_opml",
      "fetch_rss",
      "rules_regex",
      "rules_ai_natural_language",
      "ai_summary",
      "readability_extract",
      "keyboard_shortcuts",
      "folders_tags",
      "favorites",
      "mark_read"
    ],
    "v1_1": [
      "fulltext_search",
      "fever_api",
      "ai_relevance_score",
      "ai_translation"
    ],
    "v1_2": ["newsletters", "team_features", "managed_ai"]
  },

  "saas": {
    "tiers": {
      "free": {
        "price_monthly": 0,
        "trial_days": 14,
        "requires_card": true,
        "max_feeds": 50,
        "max_rules_regex": 5,
        "rules_ai": false,
        "retention_days": 30,
        "search": false,
        "fever_api": false
      },
      "pro": {
        "price_monthly": 5,
        "price_yearly": 50,
        "max_feeds": -1,
        "max_rules_regex": -1,
        "rules_ai": true,
        "retention_days": 365,
        "search": true,
        "fever_api": true,
        "newsletters": true
      },
      "team": {
        "price_monthly": 15,
        "price_yearly": 150,
        "max_users": 10,
        "max_feeds": -1,
        "max_rules_regex": -1,
        "rules_ai": true,
        "retention_days": 730,
        "search": true,
        "fever_api": true,
        "newsletters": true,
        "shared_feeds": true,
        "shared_rules": true
      }
    }
  },

  "metadata": {
    "project_name": "FeedMind",
    "version": "0.1.0",
    "created": "2026-01-27",
    "license": "AGPL-3.0",
    "repository": "github.com/[user]/feedmind"
  }
}
