{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libre-ai.fr/schemas/feed-radar/local-sync-snapshot.v0.1.schema.json",
  "title": "Feed Radar local sync snapshot v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "generated_at",
    "source_hashes",
    "seen_item_hashes",
    "selected_export_hash"
  ],
  "properties": {
    "format": {
      "const": "feedmind.local_sync_snapshot.v0.1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_hashes": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/sha256"
      }
    },
    "seen_item_hashes": {
      "type": "array",
      "maxItems": 2048,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/sha256"
      }
    },
    "selected_export_hash": {
      "oneOf": [
        {
          "$ref": "#/$defs/sha256"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-fA-F]{64}$"
    }
  }
}
