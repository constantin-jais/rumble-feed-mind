# FeedMind.ai Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# APPLICATION
# =============================================================================
RUST_LOG=feedmind_api=debug,feedmind_worker=debug,tower_http=debug
ENVIRONMENT=development

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_URL=postgres://feedmind:feedmind_dev@localhost:5432/feedmind

# =============================================================================
# CACHE & QUEUE (Redis)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# API SERVER
# =============================================================================
API_HOST=0.0.0.0
API_PORT=3001

# =============================================================================
# WORKER
# =============================================================================
WORKER_CONCURRENT_FETCHES=10
WORKER_REFRESH_INTERVAL=300

# =============================================================================
# SECURITY
# =============================================================================
# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-change-in-production

# JWT expiration in seconds (default: 7 days)
JWT_EXPIRATION=604800

# =============================================================================
# ENCRYPTION (for BYOK API keys)
# =============================================================================
# Master key for encrypting user API keys (generate with: openssl rand -base64 32)
# WARNING: Never commit real keys! Use KMS in production (see AMD-019)
MASTER_KEY=your-master-key-change-in-production

# Key version for rotation support
MASTER_KEY_VERSION=1

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# BYOK - AI PROVIDERS (Optional - users provide their own keys)
# =============================================================================
# These are only for managed AI option (future feature)
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=
